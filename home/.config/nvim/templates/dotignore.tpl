
# ==============================================================================
# SEARCH OVERRIDE FILE (.ignore)
# ==============================================================================
# This file controls what ripgrep (and Telescope) includes in search results.
# It follows the same syntax as .gitignore but is ONLY for search tools.
#
# SYNTAX EXAMPLES:
#   folder/       -> Ignore this folder and its contents
#   *.log         -> Ignore all files ending in .log
#   ! .hidden/    -> DO NOT ignore (search inside) this hidden directory
#   !secret.txt   -> DO NOT ignore this specific file
# ==============================================================================

# DO NOT ignore
# !home/.config/

# IGNORE
# *.log
# test.*
